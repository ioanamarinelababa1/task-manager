# Copy this file to .env and fill in real values. Never commit .env to git.

# Supabase PostgreSQL connection string (Session Pooler URL — not the direct connection URL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Port the NestJS API listens on
PORT=3001

# Secret used to sign short-lived access tokens (15 min). Must be >= 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string

# Secret used to sign long-lived refresh tokens (7 days). Must differ from JWT_SECRET.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string
